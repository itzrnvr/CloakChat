{
  "detection": {
    "provider": "openai",
    "provider_type": "openai",
    "base_url": "http://localhost:8000/v1",
    "model": "your-local-model.gguf",
    "api_key": "local",
    "temperature": 0.1,
    "max_tokens": 2048,
    "timeout": 30,
    "extra_body": {
      "chat_template_kwargs": {
        "enable_thinking": false
      }
    }
  },
  "cloud": {
    "provider": "openai",
    "provider_type": "openai",
    "base_url": "http://localhost:8000/v1",
    "model": "your-cloud-model",
    "api_key": "local",
    "temperature": 0.7,
    "timeout": 45,
    "reasoning_budget": 16384
  },
  "server": {
    "host": "0.0.0.0",
    "port": 8012
  },
  "simulate_cloud": false
}
